# ─── NEXUS Client Environment Variables ───────────────────────────────────────
# Copy this to .env and fill in your values
# IMPORTANT: Do NOT commit private service-account JSON or other secrets.
# Client-side Firebase config is public by design; keep server keys private.
# For Vite, env vars must begin with `VITE_` to be exposed to the client.

# Firebase (Web app) — replace the placeholders with your project's values
VITE_FIREBASE_API_KEY=AIzaSyC4hSyANF-7IDdZOYG3Qxuh4ym3fZorP1s
VITE_FIREBASE_AUTH_DOMAIN=nexus-ecb62.firebaseapp.com
VITE_FIREBASE_DB_URL=https://nexus-ecb62-default-rtdb.asia-southeast1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=nexus-ecb62
VITE_FIREBASE_STORAGE_BUCKET=nexus-ecb62.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1045731392187
VITE_FIREBASE_APP_ID=1:1045731392187:web:80429b03a09c424dc1079e
VITE_FIREBASE_MEASUREMENT_ID=G-KV9KS4H8F4

# Backend / Server
VITE_BACKEND_URL=http://localhost:5000

# Server-side secrets (DO NOT commit these to the repo). Keep them in the server
# environment or a secrets manager and reference them from the server code.
# Example server env vars (set these on Railway/Heroku/etc.):
# FIREBASE_SERVICE_ACCOUNT (the full JSON string) — store this securely on the server only
# FIREBASE_DB_URL (same as VITE_FIREBASE_DB_URL)
# GEMINI_API_KEY (server-side only for calling Gemini APIs)

# Example local server .env (server/.env) should contain:
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json  # or the JSON string in FIREBASE_SERVICE_ACCOUNT
# FIREBASE_DB_URL=REPLACE_WITH_YOUR_DATABASE_URL
# GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Notes:
# - If you generated a Firebase service account JSON (server/serviceAccountKey.json),
#   keep it out of version control and add it to .gitignore.
# - Do NOT paste private keys or the full service account JSON into client-side files.
